# -------------------------
# Virtual Environment
# -------------------------
.venv/
venv/
env/
ENV/

# -------------------------
# Python Cache
# -------------------------
__pycache__/
*.py[cod]
*$py.class

# -------------------------
# Compiled Extensions
# -------------------------
*.so

# -------------------------
# Environment Variables
# -------------------------
.env
.env.*

# -------------------------
# Jupyter
# -------------------------
.ipynb_checkpoints/

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# PyCharm
# -------------------------
.idea/

# -------------------------
# Testing
# -------------------------
.pytest_cache/
.coverage
htmlcov/

# -------------------------
# Static Analysis
# -------------------------
.mypy_cache/
.ruff_cache/
.pytype/

# -------------------------
# Build
# -------------------------
build/
dist/
*.egg-info/

# -------------------------
# Logs
# -------------------------
*.log

# -------------------------
# SQLite
# -------------------------
*.sqlite3
*.db

# -------------------------
# Streamlit Secrets
# -------------------------
.streamlit/secrets.toml

# -------------------------
# macOS / Windows
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Temporary Files
# -------------------------
tempCodeRunnerFile.py
